{
  "name": "ad-wallet-contracts",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "fp-ts": "1.19.3"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network polygonAmoy",
    "deploy:sponsored-transfer:avalanche": "NETWORK_NAME=AVALANCHE hardhat run scripts/deploy-sponsored-transfer.ts --network avalanche",
    "deploy:sponsored-transfer:base": "NETWORK_NAME=BASE hardhat run scripts/deploy-sponsored-transfer.ts --network base",
    "deploy:sponsored-transfer:bsc": "NETWORK_NAME=BNB hardhat run scripts/deploy-sponsored-transfer.ts --network bsc",
    "deploy:sponsored-transfer:giwa-sepolia": "NETWORK_NAME=GIWA_SEPOLIA hardhat run scripts/deploy-sponsored-transfer.ts --network giwaSepolia",
    "withdraw:old:avalanche": "NETWORK_NAME=AVALANCHE hardhat run scripts/withdraw-from-old-contract.ts --network avalanche"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "fp-ts": "1.19.3",
    "hardhat": "2.28.4",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5"
  }
}
