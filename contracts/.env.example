# Hardhat 배포용 — 복사: cp .env.example .env
# ⚠️ 비밀키는 Git에 커밋하지 마세요.
#
# 또는 web/frontend/.env.local 에만 두어도 됩니다:
# - PRIVATE_KEY 직접 지정, 또는
# - GIWA 배포 시 ADWALLET_SPONSOR_PK_GIWA_SEPOLIA (npm 스크립트의 NETWORK_NAME 과 매칭)

# 필수(프론트만 쓸 경우 생략 가능): 배포 지갑 프라이빗 키 (0x 접두사 있거나 없거나)
PRIVATE_KEY=

# 선택: 관리자 주소 (비우면 배포 지갑 주소 사용)
# ADMIN_ADDRESS=

# GIWA Sepolia RPC (미설정 시 hardhat.config 기본값 사용)
# GIWA_SEPOLIA_RPC_URL=https://sepolia-rpc.giwa.io
