# AD-GAS (Biconomy 미사용, 자체 Relayer)

# WalletConnect Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=demo-project-id

# Google 리워드 광고 (광고 시청 후 무료 전송) — 브라우저 전용 (Capacitor 앱에서는 사용 안 함)
# Google Ad Manager / Publisher Tag 리워드 단위 경로. 예: /12345678/rewarded
# 미설정 시 데모(카운트다운) 모달 사용.
NEXT_PUBLIC_GOOGLE_REWARDED_AD_SLOT=

# AdSense (브라우저만 로드; 네이티브 WebView에서는 스크립트 미삽입)
# 미설정 시 기본 퍼블리셔 ID 사용 (WebOnlyAdSenseScript)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# AdMob 리워드 영상 — Capacitor iOS/Android 앱(WebView) 전용
# 예: ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
NEXT_PUBLIC_ADMOB_REWARDED_AD_UNIT_ID=
# 개발 시 true 권장 (테스트 광고)
NEXT_PUBLIC_ADMOB_USE_TEST_ADS=true

# ============================================
# 체인별 RPC URL (원하는 RPC URL로 설정)
# ============================================
# Ethereum Mainnet
NEXT_PUBLIC_RPC_MAINNET=
# Base Mainnet
NEXT_PUBLIC_RPC_BASE=
# Base Sepolia (테스트넷)
NEXT_PUBLIC_RPC_BASE_SEPOLIA=
# Avalanche C-Chain
NEXT_PUBLIC_RPC_AVALANCHE=
# BNB Chain
NEXT_PUBLIC_RPC_BNB=

# ============================================
# 체인별 AD-Wallet 컨트랙트 주소
# ============================================
# Ethereum Mainnet - AD-Wallet 스폰서 컨트랙트 주소
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_ETH=
ADWALLET_CONTRACT_ADDR_ETH=

# Base Mainnet - AD-Wallet 스폰서 컨트랙트 주소
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_BASE=
ADWALLET_CONTRACT_ADDR_BASE=

# Base Sepolia (테스트넷) - AD-Wallet 스폰서 컨트랙트 주소
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_BASE_SEPOLIA=0x753097dc9Dc6d226d89b35D46f8A99d83A3F2271
ADWALLET_CONTRACT_ADDR_BASE_SEPOLIA=0x753097dc9Dc6d226d89b35D46f8A99d83A3F2271

# Avalanche C-Chain - AD-Wallet 스폰서 컨트랙트 주소
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_AVALANCHE=0xe64ffA4b21b8e8cE44Be6D44096dF7f0ba47849d
ADWALLET_CONTRACT_ADDR_AVALANCHE=0xe64ffA4b21b8e8cE44Be6D44096dF7f0ba47849d

# BNB Chain - AD-Wallet 스폰서 컨트랙트 주소
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_BNB=
ADWALLET_CONTRACT_ADDR_BNB=

# ============================================
# 체인별 스폰서 지갑 Private Key (서버 전용)
# ⚠️ 절대 공개하지 마세요! Vercel 환경 변수에만 설정하세요.
# 형식: 0x + 64자리 hex (예: 0x1234...5678)
# ============================================
# Ethereum Mainnet 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_ETH=0x07985f12d63243e64c95163681e1bdfe886d8f9bfd5e80822fb39eb7f3b3362f

# Base Mainnet 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_BASE=0x07985f12d63243e64c95163681e1bdfe886d8f9bfd5e80822fb39eb7f3b3362f

# Base Sepolia (테스트넷) 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_BASE_SEPOLIA=0x07985f12d63243e64c95163681e1bdfe886d8f9bfd5e80822fb39eb7f3b3362f

# Avalanche C-Chain 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_AVALANCHE=0x07985f12d63243e64c95163681e1bdfe886d8f9bfd5e80822fb39eb7f3b3362f

# BNB Chain 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_BNB=0x07985f12d63243e64c95163681e1bdfe886d8f9bfd5e80822fb39eb7f3b3362f
