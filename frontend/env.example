# AD-GAS (Biconomy 미사용, 자체 Relayer)
#
# 광고 운영 우선순위(권장): Android 앱(AdMob 리워드) → 브라우저 GPT(Ad Manager)는 승인 후 선택
# 안내: web/docs/ADS_APP_FIRST_KO.md · AdMob ID 넣을 위치 표: web/docs/ADMOB_WHERE_KO.md

# Capacitor 앱(WebView)에서 MetaMask 연결 시 필수 — https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# MetaMask SDK — dApp URL
# NEXT_PUBLIC_APP_URL=https://ad-gas.vercel.app
# NEXT_PUBLIC_METAMASK_USE_DEEPLINK=false

# Google 리워드 광고 — 브라우저만 (Cap 앱에서는 AdMob 사용). Ad Manager 미승인이면 비워도 됨.
# GPT 리워드 단위 경로 예: /12345678/rewarded
NEXT_PUBLIC_GOOGLE_REWARDED_AD_SLOT=

# AdSense (브라우저만 로드; 네이티브 WebView에서는 스크립트 미삽입)
# 미설정 시 기본 퍼블리셔 ID 사용 (WebOnlyAdSenseScript)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# AdMob 리워드 — 단위 ID만 여기 (ca-app-pub-xxxxxxxx/yyyy 형식, 슬래시). 앱 ID(~물결)는 넣지 않음.
# 앱 ID: Android → mobile/.../strings.xml 의 admob_app_id · iOS → Info.plist GADApplicationIdentifier
# 원격 WebView 로드 시 Vercel 등 배포 환경에도 동일 변수 필요.
# 예: NEXT_PUBLIC_ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
NEXT_PUBLIC_ADMOB_REWARDED_AD_UNIT_ID=
# (선택) 플랫폼별 단위가 다를 때만 설정
NEXT_PUBLIC_ADMOB_REWARDED_AD_UNIT_ID_IOS=
NEXT_PUBLIC_ADMOB_REWARDED_AD_UNIT_ID_ANDROID=
# 개발 시 true 권장 (테스트 광고)
NEXT_PUBLIC_ADMOB_USE_TEST_ADS=true

# ============================================
# 체인별 RPC URL (원하는 RPC URL로 설정)
# ============================================
# Base Mainnet
NEXT_PUBLIC_RPC_BASE=
# GIWA Sepolia (테스트넷, 체인 ID 91342) — 공식 RPC는 rate limit 있음. 필요 시 Flashblocks RPC(https://sepolia-rpc-flashblocks.giwa.io) 등으로 교체 가능
NEXT_PUBLIC_RPC_GIWA_SEPOLIA=
# Avalanche C-Chain
NEXT_PUBLIC_RPC_AVALANCHE=
# BNB Chain
NEXT_PUBLIC_RPC_BNB=

# ============================================
# 체인별 AD-Wallet 컨트랙트 주소
# ============================================
# Base Mainnet - AD-Wallet 스폰서 컨트랙트 주소
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_BASE=
ADWALLET_CONTRACT_ADDR_BASE=

# GIWA Sepolia (테스트넷) - AD-Wallet 스폰서 컨트랙트 주소 (배포 후 설정)
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_GIWA_SEPOLIA=
ADWALLET_CONTRACT_ADDR_GIWA_SEPOLIA=

# GIWA Sepolia — 스테이블코인 컨트랙트 (문서에 고정 주소가 없어 선택 설정; 미설정 시 해당 체인에서 USDC/USDT 전송 UI 비활성)
NEXT_PUBLIC_GIWA_SEPOLIA_USDC=
NEXT_PUBLIC_GIWA_SEPOLIA_USDT=

# Avalanche C-Chain - AD-Wallet 스폰서 컨트랙트 주소
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_AVALANCHE=0xe64ffA4b21b8e8cE44Be6D44096dF7f0ba47849d
ADWALLET_CONTRACT_ADDR_AVALANCHE=0xe64ffA4b21b8e8cE44Be6D44096dF7f0ba47849d

# BNB Chain - AD-Wallet 스폰서 컨트랙트 주소
NEXT_PUBLIC_ADWALLET_CONTRACT_ADDR_BNB=
ADWALLET_CONTRACT_ADDR_BNB=

# ============================================
# 체인별 스폰서 지갑 Private Key (서버 전용)
# ⚠️ 절대 공개하지 마세요! Vercel 환경 변수에만 설정하세요.
# 형식: 0x + 64자리 hex (예: 0x1234...5678)
# ⚠️ 예시 파일에는 실제 키를 넣지 마세요. 값은 .env.local / Vercel에만 설정.
# ============================================
# Base Mainnet 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_BASE=

# GIWA Sepolia (테스트넷) 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_GIWA_SEPOLIA=

# Avalanche C-Chain 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_AVALANCHE=

# BNB Chain 스폰서 지갑 Private Key
ADWALLET_SPONSOR_PK_BNB=
